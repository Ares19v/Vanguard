# ══════════════════════════════════════════════════════════════════
#  Vanguard ASOC — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Mode ──────────────────────────────────────────────────────────
# Set to false to enable real AWS API calls
MOCK_MODE=true

# Set to false to execute real remediations (USE WITH CAUTION)
DRY_RUN=true

# ── AWS Credentials ───────────────────────────────────────────────
# Required only when MOCK_MODE=false
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1
# AWS_SESSION_TOKEN=your_session_token_here  # only for temporary credentials

# ── Gemini AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth ──────────────────────────────────────────────────────────
# Generate a strong random secret for production:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production

# ── Database ──────────────────────────────────────────────────────
# SQLite (default) — change to PostgreSQL DSN for production
DATABASE_URL=sqlite:///./vanguard.db
